<UserControl x:Class="TaskTool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BgBrush}">
        <StackPanel>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Einstellungen" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <CheckBox Content="Outlook Sync aktiv" IsChecked="{Binding OutlookSyncEnabled}" Margin="0,0,0,12"/>
                    <TextBlock Text="Outlook Kategorie" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Text="{Binding OutlookCategoryName}" Width="260"/>
                    <TextBlock Text="Reminder Vorlauf Minuten" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Text="{Binding ReminderLeadMinutes}" Width="120"/>
                    <TextBlock Text="Datum/Zeit Format" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Text="{Binding DateTimeFormat}" Width="220"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
