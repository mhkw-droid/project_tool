<UserControl x:Class="TaskTool.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Gebuchte Stunden aktueller Monat" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding MonthSummary}" FontSize="52" FontWeight="Bold" Margin="0,4,0,12"/>

                <Border Background="#0B1220" CornerRadius="8" Height="14" Margin="0,0,0,10">
                    <Grid HorizontalAlignment="Left" Width="{Binding TotalMinutes}">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="8"/>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Breakdown}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="•  {Binding}" Margin="0,0,0,6"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
