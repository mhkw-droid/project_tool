<UserControl x:Class="TaskTool.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BgBrush}">
        <StackPanel>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Gebuchte Stunden aktueller Monat" FontSize="14" Foreground="{StaticResource MutedTextBrush}" DockPanel.Dock="Left"/>
                        <Button Content="Refresh" Width="90" DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}"/>
                    </DockPanel>

                    <TextBlock Text="{Binding MonthSummary}" FontSize="52" FontWeight="Bold" Margin="0,4,0,12"/>

                    <Border Background="#0B1220" CornerRadius="8" Height="14" Margin="0,0,0,10">
                        <Grid HorizontalAlignment="Left" Width="{Binding TotalMinutes}">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="8"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Breakdown}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,6">
                                    <Run Text="• "/><Run Text="{Binding}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Top Tasks diesen Monat" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TopTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DurationText}" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
