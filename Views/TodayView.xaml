<UserControl x:Class="TaskTool.Views.TodayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="Arbeitstag" Margin="0,0,8,8">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding WorkDaySummary}" TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="Kommen" Width="80" Margin="0,0,6,0" Command="{Binding ComeCommand}"/>
                        <Button Content="Gehen" Width="80" Margin="0,0,6,0" Command="{Binding GoCommand}"/>
                        <Button Content="Pause Start" Width="95" Margin="0,0,6,0" Command="{Binding BreakStartCommand}"/>
                        <Button Content="Pause Ende" Width="95" Command="{Binding BreakEndCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Quick Add" Margin="0,0,8,8">
                <StackPanel Margin="8">
                    <TextBox Text="{Binding QuickAddText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock FontSize="11" Foreground="Gray" Text="Format: Titel | 2026-02-25 09:00 | 45m | https://ticket/123"/>
                    <Button Content="Anlegen" Margin="0,6,0,0" Width="90" Command="{Binding QuickAddCommand}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Aufgaben heute">
                <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StartLocal, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                                <TextBlock Text="{Binding Title}" Width="180"/>
                                <TextBlock Text="{Binding Status}" Width="80"/>
                                <TextBlock Text="{Binding TicketMinutesBooked, StringFormat={}Ticket: {0}m}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="Task Details" Margin="8,0,0,0">
            <StackPanel Margin="8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="Titel"/>
                <TextBox Text="{Binding SelectedTask.Title, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Beschreibung" Margin="0,8,0,0"/>
                <TextBox Text="{Binding SelectedTask.Description, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True"/>

                <TextBlock Text="Ticket URL" Margin="0,8,0,0"/>
                <TextBox Text="{Binding SelectedTask.TicketUrl, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Start (yyyy-MM-dd HH:mm)" Margin="0,8,0,0"/>
                <TextBox Text="{Binding SelectedTask.StartLocal, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Ende (yyyy-MM-dd HH:mm)" Margin="0,8,0,0"/>
                <TextBox Text="{Binding SelectedTask.EndLocal, UpdateSourceTrigger=PropertyChanged}"/>

                <WrapPanel Margin="0,12,0,0">
                    <Button Content="Speichern" Width="90" Margin="0,0,6,0" Command="{Binding SaveCommand}"/>
                    <Button Content="Erledigt" Width="90" Margin="0,0,6,0" Command="{Binding DoneCommand}"/>
                    <Button Content="Löschen" Width="90" Command="{Binding DeleteCommand}"/>
                </WrapPanel>

                <Separator Margin="0,10,0,10"/>
                <TextBlock Text="Timer" FontWeight="Bold"/>
                <WrapPanel Margin="0,8,0,0">
                    <Button Content="Start" Width="70" Margin="0,0,6,0" Command="{Binding StartTimerCommand}"/>
                    <Button Content="Pause" Width="70" Margin="0,0,6,0" Command="{Binding PauseTimerCommand}"/>
                    <Button Content="Stop" Width="70" Margin="0,0,6,0" Command="{Binding StopTimerCommand}"/>
                    <Button Content="+15 Ticketmin" Width="110" Margin="0,0,6,0" Command="{Binding Add15Command}"/>
                    <Button Content="+30 Ticketmin" Width="110" Command="{Binding Add30Command}"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
